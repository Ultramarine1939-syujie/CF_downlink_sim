# =============================================================================
# CF-Downlink-Sim .gitignore
# =============================================================================

# ── 敏感文件 ────────────────────────────────────────────────────────────────
*.pdf
*.workbuddy/
.workbuddy
.trae
*.log

# ── MATLAB ────────────────────────────────────────────────────────────────
*.mat                           # 数据文件（训练数据、缓存）
*.fig                           # MATLAB 图形
*.mat~                          # MATLAB 备份文件
*.asv                           # MATLAB 脚本备份

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
env/
.venv/
ENV/
*.egg-info/
dist/
build/
*.whl
docs/report

# ── Jupyter ───────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── 模型文件 ───────────────────────────────────────────────────────────────
/models/
!/models/.gitkeep             # 保留目录但忽略内容

# ── 生成的数据 ─────────────────────────────────────────────────────────────
Imgs/
SimulationData/
/data/
logs/
*.h5
*.hdf5

# ── 输出目录（自动生成）────────────────────────────────────────────────────
output/
results/
checkpoints/

# ── IDE / OS ───────────────────────────────────────────────────────────────
.idea/
.vscode/
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
~$*

# ── 编译产物 ───────────────────────────────────────────────────────────────
*.mex*
*.o
*.so
*.dll
*.dylib

# ── LaTeX ────────────────────────────────────────────────────────────────
*.aux
*.bbl
*.blg
*.log
*.out
*.synctex.gz
*.toc

# ── 参考文件（本地数据）────────────────────────────────────────────────────
reference/

# ── Git ─────────────────────────────────────────────────────────────────
.git/
.gitignore                    # 不忽略自身（重置后重新创建）
